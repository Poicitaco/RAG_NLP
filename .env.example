# ============================================================
# Vietnamese Pharmaceutical RAG Assistant
# Copy this file to .env and edit local secrets there.
# Never commit real API keys or production secrets.
# ============================================================

# ----------------------------
# App
# ----------------------------
APP_NAME="Vietnamese Pharmaceutical RAG Assistant"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=True
LOG_LEVEL="INFO"

HOST="0.0.0.0"
PORT=8000
WORKERS=4

# ----------------------------
# Safety-first answer generation
# ----------------------------
# Default is False so the system can run deterministically with:
# Graph safety -> Hybrid RAG -> Evidence guardrails -> Citation-backed answer.
# Turn this on only after adding a fresh Gemini key to your local .env.
USE_LLM_ANSWER=False
LLM_PROVIDER="gemini"
LLM_MODEL="gemini-2.5-flash"
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=700
LLM_TIMEOUT_SECONDS=30
USE_LLM_PLANNER=False
LLM_PLANNER_MODEL="gemini-2.5-flash"

# Gemini constrained rewriter API key.
# If a key was exposed in chat/logs, revoke it and create a new one.
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com"

# ----------------------------
# Legacy/optional LLM providers
# ----------------------------
# These are kept for older modules. The current safe RAG path does not require
# OpenAI to run.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-opus-20240229"

# ----------------------------
# Retrieval
# ----------------------------
VECTOR_STORE_TYPE="chromadb"
CHROMA_PERSIST_DIR="./data/embeddings/chroma_priority"
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

# Chroma may be unavailable on some Windows machines if grpc DLLs are blocked.
# The current safe RAG service falls back to BM25 retrieval.

# Optional Kaggle GPU embedding endpoint exposed through Cloudflare Tunnel.
# Update this when the trycloudflare.com URL changes. Leave blank to use local CPU fallback.
KAGGLE_API_URL=""

# ----------------------------
# Semantic rule mapping
# ----------------------------
# Matrix-driven Safety Router. Uses the local embedding model by default.
RULE_EMBEDDING_PROVIDER="local"
RULE_LOCAL_EMBEDDING_MODEL="BAAI/bge-m3"
RULE_MATCH_THRESHOLD=0.48

LOCAL_EMBEDDING_MODEL="BAAI/bge-m3"
LOCAL_EMBEDDING_DIMENSION=1024
LOCAL_CHROMA_COLLECTION="pharmaceutical_local_bge_1024"

# ----------------------------
# Guardrails
# ----------------------------
ENABLE_SAFETY_CHECK=True
ENABLE_INTERACTION_WARNING=True
ENABLE_DOSAGE_VALIDATION=True
REQUIRE_MEDICAL_DISCLAIMER=True

# ----------------------------
# Database / cache
# ----------------------------
# These are optional for the current local safe RAG smoke flow.
POSTGRES_HOST="localhost"
POSTGRES_PORT=5432
POSTGRES_DB="pharma_ai"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=""

REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# ----------------------------
# Agent settings
# ----------------------------
MAX_ITERATIONS=10
AGENT_TIMEOUT=300
ENABLE_MEMORY=True

# ----------------------------
# Security / API
# ----------------------------
SECRET_KEY="dev-secret-change-me"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8000,http://localhost:8501,http://127.0.0.1:5173,http://127.0.0.1:8000"

# ----------------------------
# Uploads / limits
# ----------------------------
UPLOAD_DIR="./data/uploads"
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ----------------------------
# Monitoring
# ----------------------------
ENABLE_PROMETHEUS=True
PROMETHEUS_PORT=9090
SENTRY_DSN=""
