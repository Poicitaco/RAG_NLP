APP_NAME="Vietnamese Pharmaceutical RAG Assistant"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=True
LOG_LEVEL="INFO"

HOST="0.0.0.0"
PORT=8000

OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Optional constrained LLM rewriting.
# Do not commit real API keys. If a key is exposed in chat/logs, revoke it and create a new one.
USE_LLM_ANSWER=False
LLM_PROVIDER="gemini"
LLM_MODEL="gemini-2.5-flash"
LLM_TEMPERATURE=0.1
LLM_MAX_OUTPUT_TOKENS=700
LLM_TIMEOUT_SECONDS=30
GEMINI_API_KEY=""
GEMINI_BASE_URL="https://generativelanguage.googleapis.com"

VECTOR_STORE_TYPE="chromadb"
CHROMA_PERSIST_DIR="./data/embeddings/chroma_priority"
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
SIMILARITY_THRESHOLD=0.7

ENABLE_SAFETY_CHECK=True
ENABLE_INTERACTION_WARNING=True
ENABLE_DOSAGE_VALIDATION=True
REQUIRE_MEDICAL_DISCLAIMER=True

SECRET_KEY="change-this-in-production"
CORS_ORIGINS="http://localhost:8000"

UPLOAD_DIR="./data/uploads"
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
